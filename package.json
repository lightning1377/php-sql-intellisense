{
  "name": "php-sql-intellisense",
  "displayName": "SQL-PHP IntelliSense",
  "icon": "images/php_mysql.png",
  "publisher": "Siavash",
  "description": "MySQL IntelliSense, linting, hovers, and query helpers for PHP database calls.",
  "version": "0.5.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lightning1377/php-sql-intellisense.git"
  },
  "bugs": {
    "url": "https://github.com/lightning1377/php-sql-intellisense/issues"
  },
  "homepage": "https://github.com/lightning1377/php-sql-intellisense#readme",
  "author": {
    "name": "Siavash Kahe",
    "email": "s.kahe98@gmail.com"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "php",
    "mysql",
    "sql",
    "intellisense",
    "autocomplete",
    "lint",
    "database"
  ],
  "activationEvents": [
    "onLanguage:php"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "SQL-PHP.Intellisense.lint",
        "category": "SQL-PHP",
        "title": "Lint MySQL Queries"
      },
      {
        "command": "SQL-PHP.Intellisense.connect",
        "category": "SQL-PHP",
        "title": "Connect to MySQL Database"
      },
      {
        "command": "SQL-PHP.Intellisense.clear",
        "category": "SQL-PHP",
        "title": "Delete Database Credentials"
      }
    ],
    "configuration": [
      {
        "title": "SQL-PHP Intellisense",
        "properties": {
          "SQL-PHP.Intellisense.database.host": {
            "type": "string",
            "default": "localhost",
            "description": "MySQL server host name or IP address."
          },
          "SQL-PHP.Intellisense.database.port": {
            "type": "number",
            "default": 3306,
            "minimum": 1,
            "maximum": 65535,
            "description": "MySQL server port."
          },
          "SQL-PHP.Intellisense.database.name": {
            "type": "string",
            "default": "",
            "description": "Name of the MySQL database to inspect for tables and columns."
          },
          "SQL-PHP.Intellisense.extractionPatterns": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "Database::prepare",
              "Database::getResults",
              "Database::getValue",
              "Database::getRow",
              "Database::PrepareExecuteTC"
            ],
            "description": "List of PHP method/function names (e.g. 'Database::prepare', '$db->query') to extract SQL queries from."
          },
          "SQL-PHP.Intellisense.mockDatabase": {
            "type": "boolean",
            "default": false,
            "description": "Enable mock database connections for test and screenshot automation."
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "preui-test": "npm run compile-tests && npm run compile",
    "ui-test": "extest setup-and-run -o src/ui-test/ui-test-settings.json out/ui-test/**/*.js",
    "check-release-tag": "node scripts/check-release-tag.js",
    "vsce": "node scripts/package-vsix.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.3",
    "@types/node": "18.x",
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "@vscode/test-electron": "^2.3.6",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^8.52.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "mysql2": "^3.6.5",
    "node-sql-parser": "^4.12.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.2",
    "vscode-extension-tester": "^8.23.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "overrides": {
    "serialize-javascript": "^7.0.6"
  }
}